{
  "name": "patchwarden",
  "version": "1.6.1",
  "description": "Secure local MCP bridge for ChatGPT and local agents, with workspace-scoped task loops, safe summaries, audits, and Direct editing.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "patchwarden": "dist/index.js",
    "patchwarden-confirm": "dist/assessments/confirmCli.js",
    "patchwarden-runner": "dist/runner/cli.js"
  },
  "files": [
    "dist/",
    "!dist/test/",
    "docs/",
    "!docs/archive/",
    "!docs/optimization-proposal.md",
    "src/",
    "!src/test/",
    "examples/",
    "scripts/",
    "!scripts/control/kill-patchwarden.ps1",
    "!scripts/launchers/Kill-PatchWarden.cmd",
    "!.local/",
    "ui/",
    "PatchWarden.cmd",
    "README.md",
    "README.en.md",
    "LICENSE",
    "tsconfig.json"
  ],
  "scripts": {
    "build": "node scripts/build.js",
    "check:build-output": "node scripts/checks/build-output-check.js",
    "start": "node dist/index.js",
    "start:http": "node dist/httpServer.js",
    "start:control": "node dist/controlCenter.js",
    "dev": "npm run build && node dist/index.js",
    "runner": "node dist/runner/cli.js",
    "watch": "node dist/runner/watch.js",
    "doctor": "node dist/doctor.js",
    "doctor:ci": "node dist/doctor.js --allow-default-config",
    "test:unit": "node scripts/checks/unit-tests.js",
    "test": "node scripts/checks/build-output-check.js && node dist/smoke-test.js && node scripts/checks/unit-tests.js && node scripts/checks/lifecycle-smoke.js && node scripts/checks/doctor-smoke.js && node scripts/checks/tunnel-supervisor-smoke.js && node scripts/checks/watcher-supervisor-smoke.js && node scripts/checks/control-smoke.js && node scripts/checks/mcp-manifest-check.js && node scripts/checks/brand-check.js && node scripts/checks/control-center-smoke.js",
    "test:lifecycle": "npm run build && node scripts/checks/lifecycle-smoke.js",
    "test:doctor": "npm run build && node scripts/checks/doctor-smoke.js",
    "test:tunnel-supervisor": "npm run build && node scripts/checks/tunnel-supervisor-smoke.js",
    "test:watcher-supervisor": "npm run build && node scripts/checks/watcher-supervisor-smoke.js",
    "check:tool-manifest": "npm run build && node scripts/checks/mcp-manifest-check.js",
    "check:direct-tool-manifest": "npm run build && node scripts/checks/mcp-manifest-check.js --profile chatgpt_direct",
    "check:search-tool-manifest": "npm run build && node scripts/checks/mcp-manifest-check.js --profile chatgpt_search",
    "check:brand": "node scripts/checks/brand-check.js",
    "test:mcp": "npm run build && node scripts/checks/mcp-smoke.js",
    "test:mcp:built": "node scripts/checks/mcp-smoke.js",
    "test:http-mcp": "npm run build && node scripts/checks/http-mcp-smoke.js",
    "test:http-mcp:built": "node scripts/checks/http-mcp-smoke.js",
    "pretest": "npm run build",
    "pack:clean": "npm run build && node scripts/release/pack-clean.js",
    "pack:clean:built": "node scripts/release/pack-clean.js",
    "verify:package": "npm run build && node scripts/checks/package-manifest-check.js",
    "verify:package:built": "node scripts/checks/package-manifest-check.js",
    "desktop:install": "npm.cmd --prefix desktop install --cache ..\\.npm-cache",
    "desktop:test": "npm.cmd --prefix desktop test",
    "desktop:smoke:unpacked": "npm.cmd --prefix desktop run smoke:unpacked --",
    "desktop:stage": "npm run build && npm.cmd --prefix desktop run stage",
    "desktop:dev": "npm run build && npm.cmd --prefix desktop run dev",
    "desktop:package:dir": "npm run build && npm.cmd --prefix desktop run build:dir",
    "desktop:package": "npm run build && npm.cmd --prefix desktop run build",
    "desktop:preflight": "node scripts/release/desktop-preflight.js",
    "desktop:preflight:release": "node scripts/release/desktop-preflight.js --require-clean"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "typescript": "^7.0.2"
  },
  "overrides": {
    "@hono/node-server": "2.0.11",
    "hono": "4.12.31",
    "fast-uri": "4.1.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "codex",
    "opencode",
    "local-agent"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jiezeng2004-design/PatchWarden.git"
  },
  "bugs": {
    "url": "https://github.com/jiezeng2004-design/PatchWarden/issues"
  },
  "homepage": "https://github.com/jiezeng2004-design/PatchWarden#readme",
  "license": "MIT"
}
